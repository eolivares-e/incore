# Application
PROJECT_NAME=Insurance Core API
VERSION=0.1.0
API_V1_STR=/api/v1
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://insurance_user:insurance_pass@postgres:5432/insurance_core
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production-minimum-32-characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Security
PASSWORD_MIN_LENGTH=8
BCRYPT_ROUNDS=12

# Stripe (configure when ready to integrate payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
