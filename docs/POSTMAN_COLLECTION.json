    {
      "name": "07 - Admin",
      "item": [
        {
          "name": "Create Pricing Rule",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Auto - Low Risk Base Rate\",\n  \"description\": \"Base pricing for low-risk auto insurance\",\n  \"policy_type\": \"auto\",\n  \"risk_level\": \"low\",\n  \"base_premium\": 800.00,\n  \"multiplier_factors\": {\n    \"coverage_per_100k\": 0.05,\n    \"young_driver_multiplier\": 1.2\n  }\n}"
