            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quote_id\": \"{{quoteId}}\",\n  \"notes\": \"High-value policy requires review\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/underwriting/reviews",
              "host": ["{{baseUrl}}"],
              "path": ["underwriting", "reviews"]
            },
            "description": "Create underwriting review for a quote. Requires UNDERWRITER+ role."
          },
          "response": []
        },
        {
          "name": "Get Pending Reviews",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/underwriting/reviews/pending/all?size=10",
              "host": ["{{baseUrl}}"],
              "path": ["underwriting", "reviews", "pending", "all"],
              "query": [
                {
                  "key": "size",
                  "value": "10"
                }
              ]
            },
            "description": "Get all pending underwriting reviews, sorted by highest risk first."
          },
          "response": []
