{
  "name": "incore-frontend",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:customer": "yarn workspace customer-portal dev",
    "dev:sales": "yarn workspace sales-funnel dev",
    "dev:admin": "yarn workspace admin-portal dev",
    "dev:all": "concurrently \"yarn dev:customer\" \"yarn dev:sales\" \"yarn dev:admin\"",
    "build:customer": "yarn workspace customer-portal build",
    "build:sales": "yarn workspace sales-funnel build",
    "build:admin": "yarn workspace admin-portal build",
    "build:all": "yarn workspaces run build",
    "lint": "yarn workspaces run lint",
    "test": "yarn workspaces run test",
    "clean": "rm -rf apps/*/node_modules apps/*/.next node_modules"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
